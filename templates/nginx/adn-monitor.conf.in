# ADN Monitor — generated by adn-deploy (do not hardcode public IPs)
upstream monitorbackend {
    server ${MONITOR_APP_UPSTREAM}:${MONITOR_APP_PORT};
}

server {
    listen ${NGINX_LISTEN_DIRECTIVE};
    listen ${NGINX_LISTEN_IPV6_DIRECTIVE};
    server_name ${NGINX_SERVER_NAMES};

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

${NGINX_HTTP_INNER}
}
${NGINX_SSL_SERVER_BLOCK}
