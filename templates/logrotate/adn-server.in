${ADN_LOG_DIR}/adn-*.log
${ADN_LOG_DIR}/daprs.log
{
    daily
    rotate 7
    missingok
    compress
    delaycompress
    dateext
    dateformat -%Y-%m-%d
    extension .log
    ifempty
    create
    sharedscripts

    postrotate
        kill -USR2 $(systemctl show --property MainPID --value adn-server) 2>/dev/null || true
        kill -USR2 $(systemctl show --property MainPID --value adn-echo) 2>/dev/null || true
        kill -USR2 $(systemctl show --property MainPID --value adn-monitor) 2>/dev/null || true
        kill -USR2 $(systemctl show --property MainPID --value daprs) 2>/dev/null || true
    endscript
}
