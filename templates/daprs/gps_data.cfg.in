# Generated by adn-deploy — hbnet gps_data.py (D-APRS igate)
# Co-located with adn-server: MASTER 127.0.0.1:${DAPRS_MASTER_PORT}, local peer PORT ${DAPRS_PEER_PORT}
# Set APRS_LOGIN_CALL / APRS_LOGIN_PASSCODE before production (N0CALL = no upload).
# DATA_DMR_ID and RADIO_ID must match (default 900999 on ADN).

[GLOBAL]
PATH: ./
PING_TIME: 5
MAX_MISSED: 3
USE_ACL: True
REG_ACL: PERMIT:ALL
SUB_ACL: DENY:1
TGID_TS1_ACL: PERMIT:ALL
TGID_TS2_ACL: PERMIT:ALL

[REPORTS]
REPORT: False
REPORT_INTERVAL: 60
REPORT_PORT: 4323
REPORT_CLIENTS: 127.0.0.1

[LOGGER]
LOG_FILE: ${ADN_LOG_DIR}/daprs.log
LOG_HANDLERS: file-timed
LOG_LEVEL: DEBUG
LOG_NAME: ADN GPS/Data

[ALIASES]
TRY_DOWNLOAD: True
PATH: ${ADN_DMR_SERVER_PATH}/
PEER_FILE: peer_ids.json
SUBSCRIBER_FILE: subscriber_ids.json
TGID_FILE: talkgroup_ids.json
PEER_URL: https://servers.adn.systems/peer_ids.json
SUBSCRIBER_URL: https://servers.adn.systems/subscriber_ids.json
STALE_DAYS: 1

[GPS_DATA]
DATA_DMR_ID: ${DAPRS_DATA_DMR_ID}
CALL_TYPE: both
USER_APRS_SSID: 15
USER_APRS_COMMENT: D-APRS ADN Systems /
APRS_LOGIN_CALL: N0CALL
APRS_LOGIN_PASSCODE: 12345
APRS_SERVER: rotate.aprs2.net
APRS_PORT: 14580
IGATE_BEACON_TIME: 45
IGATE_BEACON_ICON: /I
IGATE_BEACON_COMMENT: D-APRS ADN Systems
IGATE_LATITUDE: 0000.00N
IGATE_LONGITUDE: 00000.00W
USER_SETTINGS_FILE: ${ADN_ROOT}/D-APRS/user_settings.txt
EMAIL_SENDER: test@example.org
EMAIL_PASSWORD: letmein
SMTP_SERVER: smtp.gmail.com
SMTP_PORT: 465
LOCATION_FILE: ${ADN_ROOT}/D-APRS/locations.json
BULLETIN_BOARD_FILE: ${ADN_ROOT}/D-APRS/bulletin_board.json
MAILBOX_FILE: ${ADN_ROOT}/D-APRS/mailbox.json
EMERGENCY_SOS_FILE: ${ADN_ROOT}/D-APRS/emergency_sos.json
DASHBOARD_TITLE: D-APRS Dashboard
LOGO: https://raw.githubusercontent.com/kf7eel/hblink3/gps/HBlink.png
DASH_PORT: 8092
DASH_HOST: 127.0.0.1
DESCRIPTION: ADN D-APRS gateway
CONTACT_NAME: ADN Systems
CONTACT_CALL: N0CALL
CONTACT_EMAIL: admin@example.org
CONTACT_WEBSITE: https://servers.adn.systems/
TIME_FORMAT: %%H:%%M:%%S - %%m/%%d/%%y
MAP_CENTER_LAT: 0.00
MAP_CENTER_LON: 0.00
ZOOM_LEVEL: 2
MAP_THEME: OpenStreetMap
RSS_LINK: http://127.0.0.1:8092

[IGATE]
MODE: PEER
ENABLED: True
LOOSE: False
EXPORT_AMBE: False
IP:
PORT: ${DAPRS_PEER_PORT}
MASTER_IP: 127.0.0.1
MASTER_PORT: ${DAPRS_MASTER_PORT}
PASSPHRASE: ${HBP_PASSPHRASE}
CALLSIGN: D-APRS
RADIO_ID: ${DAPRS_DATA_DMR_ID}
RX_FREQ: 000000000
TX_FREQ: 000000000
TX_POWER: 0
COLORCODE: 1
SLOTS: 2
LATITUDE: 00.0000
LONGITUDE: 000.0000
HEIGHT: 0
LOCATION: Bridge APRS
DESCRIPTION: GPS to APRS
URL: https://servers.adn.systems/
SOFTWARE_ID: 20170620
PACKAGE_ID: MMDVM_HBlink
GROUP_HANGTIME: 5
OPTIONS: TS2=${DAPRS_DATA_DMR_ID};DIAL=0;VOICE=0;LANG=es_ES;SINGLE=1;TIMER=10;
USE_ACL: True
SUB_ACL: DENY:1
TGID_TS1_ACL: PERMIT:ALL
TGID_TS2_ACL: PERMIT:ALL
