# Static Traefik config — HTTP only (default until: adn-docker ssl enable)
api:
  dashboard: false

entryPoints:
  web:
    address: ":80"
    forwardedHeaders:
      trustedIPs:
        - "127.0.0.1"
        - "::1"
        - "172.16.0.0/12"

providers:
  file:
    filename: /etc/traefik/dynamic.yml
    watch: true
